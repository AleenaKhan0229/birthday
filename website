<!DOCTYPE html>
<html>
<head>
    <title>Ahsan Birthday 🎂</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            background: linear-gradient(45deg, #ff6b6b, #4ecdc4, #45b7d1, #96ceb4, #feca57);
            background-size: 500% 500%;
            animation: gradient 10s ease infinite;
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
            overflow: hidden;
        }

        @keyframes gradient {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        h1 {
            font-size: 4em;
            margin: 0;
            text-shadow: 3px 3px 10px rgba(0,0,0,0.5);
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-20px); }
            60% { transform: translateY(-10px); }
        }

        .name {
            font-size: 5em;
            font-weight: bold;
            color: #FFD700;
            margin: 20px 0;
            text-shadow: 4px 4px 15px rgba(0,0,0,0.7);
        }

        .cake {
            font-size: 6em;
            margin: 30px 0;
            animation: shake 1s infinite;
        }

        @keyframes shake {
            0%, 100% { transform: rotate(0deg); }
            25% { transform: rotate(-5deg); }
            75% { transform: rotate(5deg); }
        }

        .buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            justify-content: center;
            margin-top: 40px;
        }

        button {
            padding: 20px 40px;
            font-size: 20px;
            font-weight: bold;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            color: white;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
            transition: all 0.3s;
            min-width: 200px;
        }

        button:hover {
            transform: translateY(-10px) scale(1.1);
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
        }

        .btn1 { background: linear-gradient(45deg, #FF6B6B, #FF8E53); }
        .btn2 { background: linear-gradient(45deg, #4ECDC4, #44A08D); }
        .btn3 { background: linear-gradient(45deg, #F093FB, #F5576C); }
        .btn4 { background: linear-gradient(45deg, #FA709A, #FEE140); }

        .hidden {
            display: none !important;
        }

        .page {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            background: linear-gradient(45deg, #ff6b6b, #4ecdc4, #45b7d1);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            animation: slideIn 0.5s ease;
        }

        @keyframes slideIn {
            from { transform: translateX(100%); }
            to { transform: translateX(0); }
        }

        .back-btn {
            position: absolute;
            top: 30px;
            left: 30px;
            padding: 15px 25px;
            font-size: 16px;
            background: rgba(255,255,255,0.3);
        }

        .age-number {
            font-size: 10em;
            color: gold;
            font-weight: bold;
            text-shadow: 5px 5px 20px rgba(0,0,0,0.8);
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }

        .gallery {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            max-width: 800px;
            max-height: 60vh;
            overflow-y: auto;
            padding: 20px;
            scrollbar-width: thin;
            scrollbar-color: #FFD700 rgba(255,255,255,0.3);
        }

        .gallery::-webkit-scrollbar {
            width: 12px;
        }

        .gallery::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.1);
            border-radius: 10px;
        }

        .gallery::-webkit-scrollbar-thumb {
            background: linear-gradient(45deg, #FFD700, #FF6B6B);
            border-radius: 10px;
            border: 2px solid rgba(255,255,255,0.2);
        }

        .gallery::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(45deg, #FF8E53, #FECA57);
        }

        .gallery img {
            width: 200px;
            height: 200px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            object-fit: cover;
            transition: transform 0.3s;
        }

        .gallery img:hover {
            transform: scale(1.05);
        }
    </style>
</head>
<body>
    <!-- 🎵 BIRTHDAY MUSIC (Auto plays!) -->
 <!-- 🎵 AUTO MUSIC - Works 100%! -->
<div id="musicStatus" style="position:fixed;top:20px;right:20px;background:rgba(0,0,0,0.8);padding:15px 25px;border-radius:25px;font-weight:bold;box-shadow:0 10px 30px rgba(0,0,0,0.4);z-index:1000;">🎵 LOADING...</div>



    <!-- PAGE 1: WELCOME SCREEN -->
    <div id="welcomePage">
        <h1>🎉 HAPPY BIRTHDAY! 🎉</h1>
        <div class="name">AHSAN MUSTAFA</div>
        <div class="cake">🎂✨🎂</div>
        <p style="font-size: 2em; margin: 20px;">Click buttons to start adventure!</p>
        
        <div class="buttons">
            <button class="btn1" onclick="showAge()">🎈 AGE REVEAL</button>
            <button class="btn2" onclick="showGallery()">🖼️ PHOTO GALLERY</button>
            <button class="btn3" onclick="showWishes()">💝 SPECIAL WISHES</button>
            <button class="btn4" onclick="showGame()">🎮 PLAY GAME</button>
        </div>
    </div>

    <!-- PAGE 2: AGE SCREEN -->
    <div id="agePage" class="page hidden">
        <button class="back-btn" onclick="showWelcome()">← Back</button>
        <h1>🥳 YOUR AGE REVEAL! 🥳</h1>
        <div class="age-number" id="ageNumber">22</div>
        <p style="font-size: 2em;">Another amazing year! 🌟</p>
        <button class="btn1" onclick="launchFireworks()" style="margin-top: 30px;">🎆 FIREWORKS!</button>
    </div>

    <!-- PAGE 3: GALLERY WITH SCROLLBAR -->
    <div id="galleryPage" class="page hidden">
        <button class="back-btn" onclick="showWelcome()">← Back</button>
        <h1>📸 MEMORY GALLERY 📸</h1>
        <div class="gallery">
            <img src="image11.png.jpeg" alt="Happy Ahsan">
            <img src="image16.png.jpeg" alt="Birthday">
            <img src="image7.png.jpeg" alt="Friends">
            <img src="image4.png.jpeg" alt="Celebration">
            <img src="image5.png.jpeg" alt="Cake">
            <img src="image10.png.jpeg" alt="Party">
            <img src="image1.png.jpeg" alt="Memories">
            <img src="image14.png.jpeg" alt="Fun Times">
            <img src="image13.png.jpeg" alt="Special Moments">
            <img src="image6.png.jpeg" alt="Celebration">
            <img src="image9.png.jpeg" alt="Birthday Vibes">
            <img src="image12.png.jpeg" alt="Amazing Memories">
        </div>
    </div>

    <!-- PAGE 4: WISHES -->
    <div id="wishesPage" class="page hidden">
        <button class="back-btn" onclick="showWelcome()">← Back</button>
        <h1>💖 SPECIAL WISHES 💖</h1>
        <div style="font-size: 1.5em; max-width: 600px; line-height: 1.8;">
            <p>🎯 May all your dreams come true!</p>
           💫 Unlimited success in all your dreams<br>
                🎯 Achievement of all your goals<br>
                ❤️ Love and happiness that overflows<br>
                🤝 Amazing friendships that last forever<br>
                🌟 Health, wealth, and endless joy! 
        </div>
        <button class="btn3" onclick="showConfetti()" style="margin-top: 40px;">🎊 CONFETTI!</button>
    </div>

    <!-- PAGE 5: GAME -->
    <div id="gamePage" class="page hidden">
        <button class="back-btn" onclick="showWelcome()">← Back</button>
        <h1>🎮 CATCH THE CAKE! 🎮</h1>
        <div style="font-size: 2em; margin: 20px;">Score: <span id="gameScore">0</span></div>
        <canvas id="gameCanvas" width="400" height="300"></canvas>
        <p style="font-size: 1.2em; margin-top: 20px;">Move mouse to catch falling cakes! 🎂</p>
    </div>

 <script>
    // 🎵 AUTO MUSIC - Starts on first interaction!
    let musicReady = false;
    let musicPlaying = false;
    const audio1 = new Audio('song.html.mp3');
        audio1.loop =  true;
    

    function startMusic() {
        if (!musicPlaying && musicReady) {
            audio1.play().then(() => {
                document.getElementById('musicStatus').innerHTML = '🎵 HAPPY BIRTHDAY PLAYING! ✨';
                musicPlaying = true;
            }).catch(() => {
                audio2.play();
                document.getElementById('musicStatus').innerHTML = '🎵 CELEBRATION MUSIC ON! 🎉';
            });
        }
    }

    // Auto-trigger music
    ['mousemove','click','touchstart','scroll'].forEach(e => {
        document.addEventListener(e, startMusic);
    });
    
    audio1.addEventListener('canplaythrough', () => {
        musicReady = true;
        document.getElementById('musicStatus').innerHTML = '🎵 READY - Move mouse/click!';
    });

    // YOUR ORIGINAL FUNCTIONS (unchanged)
    function showWelcome() {
        hideAllPages();
        document.getElementById('welcomePage').classList.remove('hidden');
    }

    function showAge() {
        hideAllPages();
        document.getElementById('agePage').classList.remove('hidden');
        startMusic(); // Ensure music plays
    }

    function showGallery() {
        hideAllPages();
        document.getElementById('galleryPage').classList.remove('hidden');
        startMusic();
    }

    function showWishes() {
        hideAllPages();
        document.getElementById('wishesPage').classList.remove('hidden');
        startMusic();
    }

    function showGame() {
        hideAllPages();
        document.getElementById('gamePage').classList.remove('hidden');
        startGame();
        startMusic();
    }

    function hideAllPages() {
        document.querySelectorAll('.page, #welcomePage').forEach(page => {
            page.classList.add('hidden');
        });
    }

    // Fireworks, Confetti, Game (YOUR ORIGINAL CODE - unchanged)
    function launchFireworks() {
        for(let i = 0; i < 50; i++) {
            setTimeout(() => createFirework(), i * 100);
        }
    }

    function createFirework() {
        const firework = document.createElement('div');
        firework.style.cssText = `
            position: fixed; left: ${Math.random() * 100}vw; top: ${Math.random() * 100}vh;
            width: 6px; height: 6px; background: hsl(${Math.random()*360}, 100%, 60%);
            border-radius: 50%; pointer-events: none; animation: explode 2s ease-out forwards;
            z-index: 1000;
        `;
        document.body.appendChild(firework);
        setTimeout(() => firework.remove(), 2000);
    }

    function showConfetti() {
        for(let i = 0; i < 100; i++) {
            setTimeout(() => {
                const confetti = document.createElement('div');
                confetti.innerHTML = ['🎉','🎊','✨','⭐','💫'][Math.floor(Math.random()*5)];
                confetti.style.cssText = `
                    position: fixed; left: ${Math.random() * 100}vw; top: -10px;
                    font-size: 2em; pointer-events: none; animation: fall 3s linear forwards;
                    z-index: 1000;
                `;
                document.body.appendChild(confetti);
                setTimeout(() => confetti.remove(), 3000);
            }, i * 30);
        }
    }
 // 🎮 PERFECT CATCH GAME
    let score = 0, gameActive = false, basketX = 200, cakes = [];
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');

    canvas.addEventListener('mousemove', e => {
        if (!gameActive) return;
        const rect = canvas.getBoundingClientRect();
        basketX = Math.max(40, Math.min(360, e.clientX - rect.left));
    });

    canvas.addEventListener('touchmove', e => {
        if (!gameActive) return;
        e.preventDefault();
        const rect = canvas.getBoundingClientRect();
        basketX = Math.max(40, Math.min(360, e.touches[0].clientX - rect.left));
    });

    function startGame() {
        gameActive = true;
       
        cakes = [];
        document.getElementById('gameScore').textContent = '0';
        canvas.style.cursor = 'pointer';
        gameLoop();
    }

    function gameLoop() {
        if (!gameActive) return;
        
        ctx.clearRect(0, 0, 400, 400);
        
        // Spawn cakes randomly
        if (Math.random() < 0.02) cakes.push({x: Math.random()*360+20, y: -30, speed: 2+Math.random()*3});
        
        // Update & draw cakes
        for(let i = cakes.length-1; i >= 0; i--) {
            const cake = cakes[i];
            cake.y += cake.speed;
            
            // Draw cake
            ctx.save();
            ctx.translate(cake.x, cake.y);
            ctx.rotate((cake.y-100)*0.01);
            ctx.fillStyle = '#D2691E';
            ctx.fillRect(-18, -18, 36, 36);
            ctx.fillStyle = '#FF4500';
            ctx.font = 'bold 28px Arial';
            ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
            ctx.fillText('🎂', 0, 0);
            ctx.restore();
            
            // CAUGHT! - Collision detection
            if (cake.y > 320 && Math.abs(cake.x - basketX) < 40) {
                score += 100;
                document.getElementById('gameScore').textContent = score;
                createFirework();
                cakes.splice(i, 1); // Remove caught cake
                continue;
            }
            
            // Remove off-screen cakes
            if (cake.y > 450) cakes.splice(i, 1);
        }
        
        // Draw basket
        ctx.fillStyle = '#8B4513';
        ctx.fillRect(basketX-35, 340, 70, 40);
        ctx.fillStyle = '#FFD700';
        ctx.fillRect(basketX-25, 330, 50, 30);
        ctx.fillStyle = 'white';
        ctx.font = 'bold 20px Arial';
        ctx.textAlign = 'center';
        ctx.fillText('🧺', basketX, 365);
        
        // UI
        ctx.fillStyle = 'rgba(255,255,255,0.9)';
        ctx.font = 'bold 28px Arial';
        ctx.textAlign = 'left';
        ctx.fillText('Score: ' + score, 20, 40);
        ctx.textAlign = 'center';
        ctx.font = 'bold 18px Arial';
        ctx.fillText('Move basket to catch cakes!', 200, 380);
        
        ctx.textAlign = 'left';
        requestAnimationFrame(gameLoop);
    }

    // Auto fireworks
    setTimeout(launchFireworks, 1000);

    // CSS
    const style = document.createElement('style');
    style.innerHTML = `@keyframes explode{to{transform:scale(20) translateY(-200vh);opacity:0}}@keyframes fall{to{transform:translateY(120vh) rotate(720deg);opacity:0}}`;
    document.head.appendChild(style);
</script>

</body>
</html>
